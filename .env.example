# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=taskflow
DB_PASSWORD=taskflow
DB_NAME=taskflow

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED: Change this to a long random string in production
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-please

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=8080

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the browser uses to reach the API
# In Docker: http://localhost:8080
# In production: https://api.yourdomain.com
VITE_API_URL=http://localhost:8080
